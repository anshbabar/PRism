# PRism configuration — copy to `.env` and fill in as needed.
# `.env` is git-ignored. NEVER commit real secrets.

# --- Core ---
APP_NAME=PRism
ENVIRONMENT=local            # local | ci | production
LOG_LEVEL=info

# --- Database ---
# Matches docker-compose.yml. Uses the psycopg (v3) driver.
DATABASE_URL=postgresql+psycopg://prism:prism@localhost:5432/prism

# --- LLM (used from a later milestone) ---
LLM_PROVIDER=mock            # mock | anthropic   (mock = offline, no key needed)
LLM_MODEL=claude-opus-4-8
LLM_MAX_TOKENS=4096
ANTHROPIC_API_KEY=           # required only when LLM_PROVIDER=anthropic

# --- Retrieval / embeddings ---
EMBEDDING_PROVIDER=hash      # hash = offline, deterministic (default); real providers plug in later
EMBED_DIM=256                # embedding vector dimension
SIMILAR_TOP_K=5              # how many similar prior PRs to return

# --- GitHub App (used from a later milestone) ---
GITHUB_APP_ID=
GITHUB_WEBHOOK_SECRET=
POST_REVIEWS=false           # gate on actually posting reviews to GitHub

# --- Frontend ---
# Base URL the Next.js app uses to reach the backend.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
